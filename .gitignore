# ------------------------------------------------------------
# This file prevents build artifacts, IDE settings, and logs
# from being committed. Do not modify unless instructed.
# ------------------------------------------------------------

# Java class files
*.class

# Logs and debug output
*.log
*.out
*.tmp
*.dat
hs_err_pid*
replay_pid*

# Maven output
**/target/
**/test-logs/
**/surefire-reports/
**/jacoco.exec
**/test-results/

# Eclipse
.project
.classpath
.settings/

# IntelliJ IDEA
.idea/
*.iml

# VS Code
.vscode/

# Packaging formats
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Keep Maven Wrapper JAR
!.mvn/wrapper/maven-wrapper.jar

# BlueJ
*.ctxt

# J2ME
.mtj.tmp/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# miscellaneous
**/archive/
